---
import { Markdown } from '#src/posts';
import styles from '#src_astro/styles/posts.module.scss';
import { Page } from 'astro';

const {
  posts,
  page = null,
  currentTag = null, 
} = Astro.props as {
  posts: Markdown[],
  page: Page | null,
  currentTag: string | null,
};

import PageNavigator from './_PageNavigator.astro';

import * as path from 'node:path';
const divs = import.meta.dirname.split(/[\/\\]/);
const baseAbsPath = path.join(import.meta.env.BASE_URL, ...divs.slice(divs.lastIndexOf('pages') + 1));
---
<div>
  <PageNavigator page={page} />
  <ul class={styles.post_list}>
    {(page.url.prev)?
      <li class={styles.post_item_dots}>
        <a href={page.url.prev} title="Previous">⋮</a>
      </li>:
      null
    }
    {posts.map((post) => (
      <li class={styles.post_item}>
        <time datetime={post.createdAt.toISO()}>{post.createdAt.toISODate()}</time>
        <a class={styles.post_title} href={`${baseAbsPath}/${post.id}`}>{post.title}</a>
        <div class={styles.tags}>
          {/* <span class={styles.tags_label}>Tags:</span> */}
          <ul class={styles.tag_list}>
            {post.tags.map((tag) => {
              const tagLower = tag.toLocaleLowerCase();
              return <li class={styles.tag_item}>{
                (tagLower === currentTag)?
                  tag:
                  <a href={`${baseAbsPath}/tag-${tagLower}`}>{tag}</a>
              }</li>
            })}
          </ul>
        </div>
      </li>
    ))}
    {(page.url.next)?
      <li class={styles.post_item_dots}>
        <a href={page.url.next} title="Next">⋮</a>
      </li>:
      null
    }
  </ul>
  <PageNavigator page={page} />
</div>
