---
import Index from './index.astro';
import { Markdown } from '#src/posts';
import { getPostStaticPaths } from '#src_astro/lib/posts';

export async function getStaticPaths() {
  return await getPostStaticPaths(['desc']);
}

const { year } = Astro.params as { year: string};
const posts = Astro.props.posts as Markdown[];
--- 
<Index title=`Posts in ${year}` posts={posts} />
