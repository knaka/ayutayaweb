---
import Page from '#src_astro/layouts/Page.astro';
import { obtainStore, Markdown } from '#src/posts';
import styles from './_styles.module.scss';

let { title, posts } = Astro.props as {
  title?: string,
  posts?: Markdown[],
};

if (!title) {
  title = 'Posts';
}

if (!posts) {
  posts = await obtainStore().postsAsync();
}

import * as path from 'node:path';
const divs = import.meta.dirname.split(/[\/\\]/);
const baseAbsPath = path.join(import.meta.env.BASE_URL, ...divs.slice(divs.lastIndexOf('pages') + 1));
---
<Page title={title}>
  <ul slot="main">
    {posts.map((post) => (
      <li class={styles.item_list}>
        <time datetime={post.createdAt.toISO()}>{post.createdAt.toISODate()}</time>
        <a href={`${baseAbsPath}/${post.id}`}>{post.title}</a>
        <div class={styles.tags}>Tags: {post.tags.join(' | ')}</div>
      </li>
    ))}
  </ul>
  <div slot="sidebar">
    <p>Sidebar content goes here.</p>
  </div>
</Page>
