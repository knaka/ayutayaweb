---
import PageLayout from '#src_astro/components/PageLayout.astro';

import PostList from './PostList.astro';
import PostRecentFrame from './PostRecentFrame.astro'

import { Page as AstroPage } from 'astro';

const { title, page } = Astro.props as {
  title: string,
  page: AstroPage,
};
---
<PageLayout title={title}>
  <PostList slot="main" posts={page.data} page={page} />
  <PostRecentFrame slot="sidebar" />
</PageLayout>
